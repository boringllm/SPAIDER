# Spider Kali server — per-deployment settings. Copy to `.env` and edit.
# These are read by docker-compose.yml at run time. Do NOT bake secrets into the shared
# image: the token/scope belong to each deployment, not to the distributable image.

# Bearer token Spider must send on every request (strongly recommended on any shared network).
# Generate one:  openssl rand -hex 24      (then set the same value in Spider → Settings → Kali)
SPIDER_KALI_TOKEN=coucou

# Comma-separated in-scope hosts/CIDRs. Tools refuse targets outside this list (server-side
# backstop). Example: 10.10.10.0/24,target.example.com   Leave blank to disable the guard.
SPIDER_SCOPE=

# Host port to publish the MCP server on (container always listens on 8765).
SPIDER_KALI_PORT=8765
